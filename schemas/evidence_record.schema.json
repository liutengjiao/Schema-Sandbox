{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SchemaSandboxEvidenceRecord",
  "type": "object",
  "required": [
    "trace_id",
    "sandbox_id",
    "sandbox_version",
    "partition_id",
    "policy_decision",
    "input_hash",
    "output_hash",
    "timestamp"
  ],
  "properties": {
    "trace_id": {
      "type": "string"
    },
    "parent_trace_id": {
      "type": "string"
    },
    "sandbox_id": {
      "type": "string"
    },
    "sandbox_version": {
      "type": "string"
    },
    "partition_id": {
      "type": "string"
    },
    "actor_agent_id": {
      "type": "string"
    },
    "model_provider": {
      "type": "string"
    },
    "model_id": {
      "type": "string"
    },
    "policy_version": {
      "type": "string"
    },
    "policy_decision": {
      "type": "string",
      "enum": [
        "allow",
        "deny",
        "ask",
        "defer"
      ]
    },
    "input_hash": {
      "type": "string"
    },
    "tool_name": {
      "type": "string"
    },
    "tool_args_hash": {
      "type": "string"
    },
    "output_hash": {
      "type": "string"
    },
    "previous_record_hash": {
      "type": "string"
    },
    "record_hash": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "digest_algorithm": {
      "type": "string",
      "enum": [
        "sha256",
        "blake3"
      ]
    }
  },
  "additionalProperties": true
}
